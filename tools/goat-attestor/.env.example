# Required
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
EPOCH_SETTLEMENT_ADDRESS=0x0000000000000000000000000000000000000001
WORKER_BINDING_ADDRESS=0x0000000000000000000000000000000000000002
ENROLLMENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000003
REGISTRY_JSON=./registry.json

# Optional / defaults
FAH_STATS_BASE=https://api.foldingathome.org
TEAM=1068318
POLL_INTERVAL_S=600
MIN_FAH_INTERVAL_MS=1000
PROPOSER_BOND_WEI=1000000000000000000
CHALLENGER_BOND_WEI=1000000000000000000
STATE_DIR=./state
EVIDENCE_DIR=./evidence
RELAYER_BIND=127.0.0.1:8787
CONFIRMATION_DEPTH=1

# --- Mock vs live ---
# GOAT_ATTESTOR_MOCK=1  → in-memory MockChain (CI / offline; no alloy RPC)
# unset / 0             → live RpcChain via alloy against RPC_URL
GOAT_ATTESTOR_MOCK=1

# Live role keys (0x-hex). Required for the roles you exercise when not in mock mode.
# Anvil default account #0 / #1 (DO NOT use on mainnet):
# PROPOSER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# WATCHER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# CHALLENGER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
# RELAYER_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# Local anvil:
#   anvil --chain-id 31337
#   # deploy contracts, set EPOCH_SETTLEMENT_ADDRESS etc. from deployment JSON
#   unset GOAT_ATTESTOR_MOCK
#   cargo run -- run
