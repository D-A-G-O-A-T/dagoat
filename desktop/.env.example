# Desktop env (Vite). Copy to `.env` / `.env.local` for local overrides.
# Never commit real secrets here.

# ---------------------------------------------------------------------------
# Attestor relayer (Phase 4 gasless bind/enroll)
# ---------------------------------------------------------------------------
# DEV (default if unset): http://127.0.0.1:8787
#   Founder runs `goat-attestor serve-relayer` on the same machine as the app.
#
# PRODUCTION / user-facing builds MUST set a remote HTTPS URL for the
# founder-operated daemon (holds gas keys). Example:
#   VITE_ATTESTOR_RELAYER_URL=https://api.your-domain.example
#
# Consultant hazard (2026-07-15): do not ship localhost to end users.
# VITE_ATTESTOR_RELAYER_URL=http://127.0.0.1:8787
