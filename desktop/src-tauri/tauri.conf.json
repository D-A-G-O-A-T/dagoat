{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "D.A. G.O.A.T.",
  "version": "0.1.0",
  "identifier": "com.goatcoin.dagoat",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "D.A. G.O.A.T.",
        "width": 460,
        "height": 720,
        "minWidth": 420,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "GoatCoin desktop node — the D.A. G.O.A.T. alpha.",
    "externalBin": ["binaries/goatd"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
