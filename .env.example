# GoatCoin Alpha Pilot — copy this file to `.env` and adjust, then run `docker compose up`.
# Docker Compose auto-loads `.env` from the project directory.

# ── The Power Dial ───────────────────────────────────────────────────────────
# CPU limit as a decimal fraction of ONE core, enforced by the OS (cgroups v2).
# This is your fan-noise / heat control. Lower = quieter and cooler; higher = faster.
#   0.1  = 10% of one core (whisper quiet)
#   0.5  = 50% of one core (a good overnight default)
#   1.0  = one full core   (default if unset)
GOATD_CPU_LIMIT=0.5
